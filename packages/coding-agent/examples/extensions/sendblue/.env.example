# Sendblue API credentials — get from https://sendblue.co/dashboard
SENDBLUE_API_KEY_ID=
SENDBLUE_API_SECRET_KEY=

# Your Sendblue phone number (E.164 format)
SENDBLUE_OWN_NUMBER=+1XXXXXXXXXX

# Comma-separated phone numbers allowed to message Pi (empty = allow all)
ALLOWED_NUMBERS=+15551234567

# Webhook security (recommended — set a random secret and configure in Sendblue dashboard)
# WEBHOOK_SECRET=your-random-secret-here

# Webhook port (default: 3001)
# WEBHOOK_PORT=3001

# Webhook bind address (default: 0.0.0.0, use 127.0.0.1 behind reverse proxy)
# WEBHOOK_HOST=0.0.0.0
