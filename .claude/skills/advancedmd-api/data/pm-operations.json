{
  "$comment": "AdvancedMD Connect API — enumerated PM/EHR operations. Each operation is an XML-RPC `ProcessRequest` invocation wrapping a <ppmdmsg action='...' class='...'> envelope. Derived from confirmed production integrations (Keragon AMD MCP, Healthjump notes) — 49 operations across 10 functional groups. The `sync_delta` group re-lists the delta-capable ops from `patients`+`visits` for discoverability; the canonical definition of each op is in its primary group. This data is for programmatic reference; see references/connect-api.md for narrative + recipes.",
  "source": {
    "extracted_from": ["Keragon AMD MCP (production)", "Healthjump AMD integration notes"],
    "extracted_at": "2026-05-23",
    "amd_product_version": "v25",
    "transport_class": "XML-RPC (ProcessRequest wrapper); some operations also exposed via newer REST Bearer-token endpoints"
  },
  "groups": {
    "patients": {
      "operations": [
        {
          "action": "findpatient",
          "class": "pat",
          "params": {
            "first": "string?",
            "middle": "string?",
            "last": "string?",
            "dob": "MM/DD/YYYY?",
            "chart": "string?",
            "phone": "string?",
            "ssn": "string?",
            "visitnumber": "string?",
            "exactmatch": "true|false?"
          },
          "returns": "patientinfo[]"
        },
        {
          "action": "getpatient",
          "class": "pat",
          "params": { "patientid": "string (e.g. pat1234)" },
          "returns": "patientinfo (full record)"
        },
        {
          "action": "getpatientdemographic",
          "class": "pat",
          "params": { "patientid": "string" },
          "returns": "demographic-only patientinfo"
        },
        {
          "action": "getpatients",
          "class": "pat",
          "params": { "maxitems": "int? (default 500)", "startindex": "int?" },
          "returns": "patientinfo[] (paged)"
        },
        {
          "action": "getpatientpreferences",
          "class": "pat",
          "params": { "patientid": "string" },
          "returns": "preferences (email/text/language/timezone)"
        },
        {
          "action": "updatepatientpreferences",
          "class": "pat",
          "params": {
            "patientid": "string",
            "emailreminders": "boolean?",
            "textreminders": "boolean?",
            "language": "string?",
            "timezone": "string?"
          },
          "returns": "ack"
        },
        {
          "action": "getpatientpaymentplan",
          "class": "pat",
          "params": { "patientid": "string" },
          "returns": "paymentplan? (or null)"
        },
        {
          "action": "getpatienttransactionhistory",
          "class": "pat",
          "params": { "responsiblepartyid": "string" },
          "returns": "transaction[]"
        },
        {
          "action": "createpatient",
          "class": "pat",
          "params": {
            "first": "string",
            "last": "string",
            "dob": "MM/DD/YYYY",
            "chart": "string|AUTO",
            "profile": "string",
            "sex": "M|F|U",
            "title": "MR|MRS|MS|MISS|DR|JR|SR|II|I?",
            "ssn": "string?",
            "email": "string?",
            "phone1": "string?",
            "addr1": "string?",
            "city": "string?",
            "state": "string?",
            "zip": "string?",
            "force": "true|false? (bypass dup detection)"
          },
          "returns": "patientinfo (created, with id)"
        },
        {
          "action": "getnewandmodifiedpatients",
          "class": "pat",
          "params": { "datechanged": "date string (varies by op)" },
          "returns": "patientinfo[]"
        },
        {
          "action": "getnewandmodifiedpatientnotes",
          "class": "note",
          "params": { "datechanged": "date", "templateid": "string" },
          "returns": "patientnote[]"
        },
        {
          "action": "createpatientnote",
          "class": "note",
          "params": {
            "patientid": "string",
            "providerid": "string",
            "templatename": "string",
            "body": "string",
            "notetypeid": "string?"
          },
          "returns": "patientnote (created)"
        }
      ]
    },
    "documents": {
      "operations": [
        {
          "action": "getfiles",
          "class": "file",
          "params": { "patientid": "string", "filetype": "string?" },
          "returns": "file[]"
        },
        {
          "action": "getpatientdocument",
          "class": "file",
          "params": { "documentid": "string" },
          "returns": "document metadata"
        },
        {
          "action": "uploadpatientdocument",
          "class": "file",
          "params": {
            "patientid": "string",
            "filetype": "string",
            "filename": "string",
            "content": "base64 string OR url"
          },
          "returns": "documentid"
        },
        {
          "action": "downloadpatientdocument",
          "class": "file",
          "params": { "documentid": "string" },
          "returns": "binary (base64)"
        }
      ]
    },
    "appointments": {
      "operations": [
        {
          "action": "getappointments",
          "class": "sched",
          "params": {
            "patientid": "string?",
            "columnid": "string?",
            "startdate": "MM/DD/YYYY?",
            "enddate": "MM/DD/YYYY?"
          },
          "returns": "appointment[]"
        },
        {
          "action": "getappointment",
          "class": "sched",
          "params": { "appointmentid": "string", "includedetails": "true|false?" },
          "returns": "appointment (single)"
        },
        {
          "action": "getopenings",
          "class": "sched",
          "params": {
            "columnids": "comma-separated string",
            "daysofweek": "comma-separated 0-6",
            "duration": "int (minutes)",
            "earliesttime": "HH:MM",
            "latesttime": "HH:MM",
            "startdate": "MM/DD/YYYY",
            "enddate": "MM/DD/YYYY"
          },
          "returns": "opening[]"
        },
        {
          "action": "getappointmentinstructions",
          "class": "sched",
          "params": {},
          "returns": "appointmentinstruction[]"
        },
        {
          "action": "getappointmenttypes",
          "class": "sched",
          "params": {},
          "returns": "appointmenttype[]"
        },
        {
          "action": "createappointment",
          "class": "sched",
          "params": {
            "patientid": "string",
            "columnid": "string",
            "startdatetime": "YYYY-MM-DDTHH:MM:SS",
            "duration": "int",
            "profileid": "string",
            "type": "string[] (array of ap_type ids)",
            "instructions": "string[]?",
            "reason": "string?",
            "notes": "string?"
          },
          "returns": "appointment (created)"
        },
        {
          "action": "updateappointment",
          "class": "sched",
          "params": {
            "appointmentid": "string",
            "action": "checkin|checkout|move|cancel|noshow|uncheckin|uncheckout",
            "newdatetime": "datetime? (move only)",
            "cancelreason": "string? (cancel only)"
          },
          "returns": "ack"
        },
        {
          "action": "createblockhold",
          "class": "sched",
          "params": {
            "columnid": "string",
            "type": "1 (block) | 2 (hold)",
            "startdatetime": "datetime",
            "duration": "int",
            "reasonid": "string"
          },
          "returns": "block_or_hold"
        }
      ]
    },
    "scheduler_setup": {
      "operations": [
        {
          "action": "getschedulersetupcolumns",
          "class": "sched",
          "params": {},
          "returns": "column[]"
        },
        {
          "action": "getschedulersetupprofiles",
          "class": "sched",
          "params": {},
          "returns": "profile[]"
        },
        {
          "action": "getreasons",
          "class": "sched",
          "params": { "type": "1 (block) | 2 (hold)" },
          "returns": "reason[]"
        },
        { "action": "getfacilities", "class": "fac", "params": {}, "returns": "facility[]" }
      ]
    },
    "billing_and_charges": {
      "operations": [
        {
          "action": "createcharge",
          "class": "chrg",
          "params": {
            "patientid": "string",
            "visitid": "string",
            "facilityid": "string",
            "providerid": "string",
            "charges": "charge_line[] (proccode, diagcodes, modcodes, units)",
            "responsibleparty": "string?"
          },
          "returns": "charge[]"
        },
        {
          "action": "getchargedetails",
          "class": "chrg",
          "params": { "chargeid": "string" },
          "returns": "charge (single)"
        },
        {
          "action": "applypaymenttocharge",
          "class": "chrg",
          "params": {
            "chargeid": "string",
            "amount": "decimal",
            "paysource": "1 (Patient) | 2 (Insurance)",
            "paymentdate": "MM/DD/YYYY",
            "paymentcode": "string?"
          },
          "returns": "ack"
        },
        {
          "action": "getpaymentsbycode",
          "class": "chrg",
          "params": {
            "paymentcode": "string",
            "startdate": "MM/DD/YYYY?",
            "enddate": "MM/DD/YYYY?"
          },
          "returns": "payment[]"
        },
        {
          "action": "getclaimstatus",
          "class": "chrg",
          "params": { "visitid": "string", "carrierid": "string?" },
          "returns": "claimstatus"
        },
        {
          "action": "getvisits",
          "class": "visit",
          "params": { "patientid": "string", "startdate": "MM/DD/YYYY?", "enddate": "MM/DD/YYYY?" },
          "returns": "visit[]"
        }
      ]
    },
    "insurance": {
      "operations": [
        {
          "action": "getcarriers",
          "class": "ins",
          "params": { "name": "string?", "exactmatch": "true|false?" },
          "returns": "carrier[]"
        },
        {
          "action": "getfinancialclasses",
          "class": "ins",
          "params": {},
          "returns": "financialclass[]"
        },
        {
          "action": "createinsurance",
          "class": "ins",
          "params": {
            "patientid": "string",
            "carrierid": "string",
            "groupid": "string?",
            "memberid": "string",
            "effectivedate": "MM/DD/YYYY",
            "priority": "PRIMARY|SECONDARY|TERTIARY",
            "relationshiptoinsured": "self|spouse|child|parent|other",
            "hipaarelationship": "string (from getHippaRelationships)",
            "insuredfirst": "string?",
            "insuredlast": "string?",
            "insureddob": "MM/DD/YYYY?",
            "copay": "decimal?",
            "deductible": "decimal?"
          },
          "returns": "insurance"
        }
      ]
    },
    "referrals": {
      "operations": [
        {
          "action": "addinboundreferral",
          "class": "ref",
          "params": {
            "patientid": "string",
            "referringproviderid": "string",
            "authorization": "string?",
            "authexpirationdate": "MM/DD/YYYY?",
            "visitscount": "int?"
          },
          "returns": "referral"
        },
        {
          "action": "getreferringproviders",
          "class": "ref",
          "params": {},
          "returns": "referringprovider[]"
        },
        {
          "action": "getreferralstatuses",
          "class": "ref",
          "params": {},
          "returns": "referralstatus[]"
        }
      ]
    },
    "codes": {
      "operations": [
        {
          "action": "getdiagnosiscodes",
          "class": "code",
          "params": { "code": "string? (filter)" },
          "returns": "diagnosiscode[] (ICD-10/9)"
        },
        {
          "action": "getprocedurecodes",
          "class": "code",
          "params": { "code": "string? (filter)" },
          "returns": "procedurecode[] (CPT/HCPCS)"
        },
        {
          "action": "getmodifiercodes",
          "class": "code",
          "params": {},
          "returns": "modifiercode[]"
        },
        { "action": "getnotetemplates", "class": "note", "params": {}, "returns": "notetemplate[]" }
      ]
    },
    "providers": {
      "operations": [
        { "action": "getproviders", "class": "prov", "params": {}, "returns": "provider[]" }
      ]
    },
    "intake": {
      "operations": [
        {
          "action": "getintakerecords",
          "class": "intake",
          "params": {
            "startdate": "MM/DD/YYYY?",
            "enddate": "MM/DD/YYYY?",
            "status": "1653 (new) | 1654 (approved) | 1655 (declined)?"
          },
          "returns": "intakerecord[]"
        },
        {
          "action": "createintakerecord",
          "class": "intake",
          "params": {
            "patientid": "string?",
            "formname": "string",
            "fields": "object (form-specific)",
            "submitteddate": "YYYY-MM-DDTHH:MM:SS.sssZ?"
          },
          "returns": "intakerecord"
        }
      ]
    },
    "sync_delta": {
      "operations": [
        {
          "action": "getnewandmodifiedpatients",
          "class": "pat",
          "params": { "datechanged": "date string" },
          "returns": "patientinfo[]"
        },
        {
          "action": "getnewandmodifiedpatientnotes",
          "class": "note",
          "params": { "datechanged": "date string", "templateid": "string" },
          "returns": "patientnote[]"
        },
        {
          "action": "getnewandmodifiedvisits",
          "class": "visit",
          "params": { "datechanged": "date string" },
          "returns": "visit[]"
        }
      ]
    }
  },
  "id_prefixes": {
    "pat": "Patient",
    "prov": "Provider",
    "rprov": "Referring Provider",
    "mprov": "Provider profile (master)",
    "prof": "Profile",
    "col": "Scheduler column",
    "fac": "Facility",
    "car": "Insurance carrier",
    "pcode": "Procedure code",
    "dcode": "Diagnosis code",
    "ap_type": "Appointment type",
    "ap_instr": "Appointment instruction",
    "stat": "Referral status",
    "note": "Note type",
    "chg": "Charge",
    "ins": "Insurance",
    "visit": "Visit",
    "apt": "Appointment"
  },
  "common_enums": {
    "sex": ["M", "F", "U"],
    "title": ["MR", "MRS", "MS", "MISS", "DR", "JR", "SR", "II", "I"],
    "marital_status": ["S", "M", "D", "W", "P", "U"],
    "appointment_status": ["SCHEDULED", "CHECKEDIN", "COMPLETED", "NOSHOW", "CANCELLED"],
    "appointment_update_action": [
      "checkin",
      "checkout",
      "move",
      "cancel",
      "noshow",
      "uncheckin",
      "uncheckout"
    ],
    "charge_status": ["UNBILLED", "BILLED", "REJECTED", "PAID", "ADJUSTED", "WRITTENOFF"],
    "insurance_priority": ["PRIMARY", "SECONDARY", "TERTIARY"],
    "relationship_to_insured": ["self", "spouse", "child", "parent", "other"],
    "paysource": { "1": "Patient", "2": "Insurance" },
    "block_hold_type": { "1": "block", "2": "hold" },
    "intake_record_status": { "1653": "new", "1654": "approved", "1655": "declined" },
    "connect_error_codes": {
      "0": "Auth failure",
      "1": "Bad request (missing required field)",
      "2": "Validation error",
      "5": "Not found",
      "9": "Duplicate detected",
      "15": "Permission denied",
      "99": "Generic server error",
      "100": "Throttle / rate limit"
    }
  }
}
