# Per-host secrets for gautams-imac (user: exult). Copy to gautams-imac-exult.env.

# sendblue-channel
SENDBLUE_API_KEY_ID=
SENDBLUE_API_SECRET_KEY=

# teams-channel
MSTEAMS_APP_ID=
MSTEAMS_APP_PASSWORD=
MSTEAMS_TENANT_ID=

# Shared bearer for HTTP-launched MCP channels (advancedmd, ringcentral,
# ringcentral-admin, docstrange, rippling, email, teams-mcp) -- all served
# from claude-cloud's Tailscale funnel.
MCP_BEARER_TOKEN=
