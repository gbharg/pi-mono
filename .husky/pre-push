#!/bin/sh

# Get the current branch name
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Allow main branch to bypass validation
if [ "$CURRENT_BRANCH" = "main" ] || [ "$CURRENT_BRANCH" = "master" ] || [ "$CURRENT_BRANCH" = "develop" ]; then
  echo "✅ Main branch detected, skipping branch name validation."
  exit 0
fi

echo "Validating branch name: $CURRENT_BRANCH"

# Define the valid branch name pattern
# Format: <type>/<description>
# Types: feat|fix|chore|docs|refactor|test|ci|perf
# Description: lowercase alphanumerics and hyphens (kebab-case)
# No consecutive hyphens, no leading/trailing hyphens
BRANCH_PATTERN="^(feat|fix|chore|docs|refactor|test|ci|perf)/[a-z0-9][a-z0-9-]*[a-z0-9]$"

# Check if branch name matches the pattern
if echo "$CURRENT_BRANCH" | grep -qE "$BRANCH_PATTERN"; then
  # Additional validation: no consecutive hyphens
  if echo "$CURRENT_BRANCH" | grep -qE "--"; then
    echo "❌ Branch name validation failed!"
    echo "   Branch: $CURRENT_BRANCH"
    echo "   Error: Branch name contains consecutive hyphens"
    echo ""
    echo "Valid format: <type>/<description>"
    echo "Valid types: feat, fix, chore, docs, refactor, test, ci, perf"
    echo "Description rules:"
    echo "  - Use kebab-case: lowercase letters, numbers, and hyphens"
    echo "  - No consecutive hyphens"
    echo "  - No leading or trailing hyphens"
    echo ""
    echo "Examples:"
    echo "  ✅ feat/linear-webhook"
    echo "  ✅ fix/subagent-hang"
    echo "  ✅ docs/changelog-audit"
    echo "  ✅ chore/update-dependencies"
    echo "  ❌ feat/Linear-Webhook (uppercase)"
    echo "  ❌ fix/memory--leak (consecutive hyphens)"
    echo "  ❌ feat/-new-feature (leading hyphen)"
    echo ""
    echo "See .pi/RULES.md for complete specification."
    exit 1
  fi
  
  echo "✅ Branch name validation passed!"
else
  echo "❌ Branch name validation failed!"
  echo "   Branch: $CURRENT_BRANCH"
  echo "   Error: Branch name does not follow conventional branch format"
  echo ""
  echo "Valid format: <type>/<description>"
  echo "Valid types: feat, fix, chore, docs, refactor, test, ci, perf"
  echo "Description rules:"
  echo "  - Use kebab-case: lowercase letters, numbers, and hyphens"
  echo "  - No consecutive hyphens"
  echo "  - No leading or trailing hyphens"
  echo ""
  echo "Examples:"
  echo "  ✅ feat/linear-webhook"
  echo "  ✅ fix/subagent-hang"
  echo "  ✅ docs/changelog-audit"
  echo "  ✅ chore/update-dependencies"
  echo "  ❌ feat/Linear-Webhook (uppercase)"
  echo "  ❌ fix/memory--leak (consecutive hyphens)"
  echo "  ❌ feat/-new-feature (leading hyphen)"
  echo ""
  echo "See .pi/RULES.md for complete specification."
  exit 1
fi