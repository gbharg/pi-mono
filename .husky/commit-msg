#!/usr/bin/env bash

# Husky commit-msg hook for conventional commits validation
# Validates commit messages against conventional commit format

# Define allowed commit message patterns
commit_msg_type_regex='feat|fix|chore|docs|refactor|test|ci|perf'
commit_msg_scope_regex='[a-z0-9-]+'
commit_msg_description_regex='[a-z].{0,99}'
commit_msg_regex="^(${commit_msg_type_regex})(\(${commit_msg_scope_regex}\))?!?: (${commit_msg_description_regex})$"

# Special cases for git operations
merge_msg_regex="^Merge"
initial_commit_regex="^chore: init$"

# Read the commit message
commit_msg_header=$(head -n1 "$1")

# Check if commit message matches conventional commit format
if [[ "$commit_msg_header" =~ $commit_msg_regex ]] || \
   [[ "$commit_msg_header" =~ $merge_msg_regex ]] || \
   [[ "$commit_msg_header" =~ $initial_commit_regex ]]; then
  exit 0
fi

# If we get here, the commit message is invalid
echo "❌ Invalid commit message format!"
echo ""
echo "Your commit message:"
echo "  $commit_msg_header"
echo ""
echo "Conventional commit format:"
echo "  type(scope): description"
echo ""
echo "Types: feat, fix, chore, docs, refactor, test, ci, perf"
echo "Scope: optional, describes the area (e.g. ai, coding-agent, memory)"
echo "Description: imperative mood, lowercase, no period"
echo ""
echo "Examples:"
echo "  feat(ai): add bedrock provider"
echo "  fix(coding-agent): prevent subagent hang"
echo "  docs: update changelog"
echo "  chore(deps): bump express to v5"
echo ""
echo "For breaking changes, add '!' before the colon:"
echo "  feat(api)!: remove deprecated endpoint"

exit 1